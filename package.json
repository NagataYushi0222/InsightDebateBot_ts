{
  "name": "insightdebatebot",
  "version": "1.0.0",
  "description": "Discord上のボイスチャットを自動録音・分析し、議論の要約や対立構造を可視化するAI Botです。",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "kill-win": "taskkill /F /IM node.exe || exit 0",
    "start-fresh": "npm run kill-win && npm run dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
