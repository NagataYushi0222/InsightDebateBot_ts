  },
  "homepage": "https://github.com/NagataYushi0222/InsightDebateBot#readme",
  "dependencies": {
    "@google/genai": "^1.41.0",
    "@noble/ciphers": "^2.1.1",
    "@ovencord/util": "^1.10.0",
    "@ovencord/voice": "^0.19.8",
    "@snazzah/davey": "^0.1.10",
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.4",
    "ffmpeg-static": "^5.3.0",
